# Dev defaults for Codespaces / Dev Containers
# Copy to .env or set in devcontainer.json remoteEnv
# NO real keys — get them from 1Password / Railway dashboard

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
USE_MOCK_VISION=true

TRADERA_APP_ID=
TRADERA_APP_KEY=
USE_MOCK_EASYOCR=true
USE_MOCK_EMBEDDING=true
USE_MOCK_GOOGLE_VISION=true

DATABASE_URL=postgresql+asyncpg://postgres:dev@db:5432/valuation
ADMIN_SECRET_KEY=dev-secret-change-me
ALLOWED_ORIGINS=http://localhost:8000,https://*.preview.app.github.dev

CRAWLER_ENABLED=false
CRAWLER_USE_SERPER=false
AGENT_ENABLED=false
