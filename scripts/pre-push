#!/bin/sh
# pre-push hook — runs tests before allowing push.
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Or: bash scripts/install_hook.sh

echo "Running tests before push..."
REPO_DIR="$(git rev-parse --show-toplevel)"
if ! sh "$REPO_DIR/scripts/stage_ready_check.sh"; then
    echo ""
    echo "Tests failed — push aborted."
    echo "Fix the failing tests and try again."
    exit 1
fi

echo "Stage-ready checks passed — pushing."
