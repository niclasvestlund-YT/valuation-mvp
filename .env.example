# OpenAI Vision API
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=3

# Set to true to skip real vision calls (useful for local testing without burning API credits)
USE_MOCK_VISION=false

# Tradera marketplace API — get credentials at developer.tradera.com
TRADERA_APP_ID=
TRADERA_APP_KEY=
# TRADERA_TIMEOUT_SECONDS=20  # optional, default 20

# Serper.dev — primary new-price source (Google Shopping) — get key at serper.dev
SERPER_DEV_API_KEY=

# SerpAPI — optional fallback for new price + used market — get key at serpapi.com
SERPAPI_API_KEY=
# SERPAPI_TIMEOUT_SECONDS=20  # optional, default 20
# SERPAPI_ENGINE=google_shopping  # optional
# SERPAPI_LOCATION=Sweden  # optional
# SERPAPI_GL=se  # optional
# SERPAPI_HL=sv  # optional

# Database — local dev: run `make db` first to start PostgreSQL in Docker
# On Railway: DATABASE_URL is set automatically when you add the PostgreSQL plugin
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/valuation

# Security — admin dashboard authentication
ADMIN_SECRET_KEY=your-secret-here

# CORS — comma-separated allowed origins (default: localhost only)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
